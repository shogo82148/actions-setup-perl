{
  "name": "actions-setup-perl",
  "version": "0.0.0",
  "description": "",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "package": "npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "test": "node --experimental-vm-modules --no-warnings node_modules/jest/bin/jest.js",
    "all": "npm run format:write && npm run lint && npm run test && npm run package"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/shogo82148/actions-setup-perl.git"
  },
  "author": "ICHINOSE Shogo",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shogo82148/actions-setup-perl/issues"
  },
  "homepage": "https://github.com/shogo82148/actions-setup-perl#readme",
  "dependencies": {
    "@actions/cache": "^6.0.0",
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^4.0.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@types/semver": "^7.7.1",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "ts-jest": "^29.4.9",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^6.0.3"
  }
}
